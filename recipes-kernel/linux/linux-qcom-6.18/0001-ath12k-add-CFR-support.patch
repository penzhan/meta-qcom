+int ath12k_wmi_peer_set_cfr_capture_conf(struct ath12k *ar,
+					u32 vdev_id, const u8 *mac_addr,
+					struct wmi_peer_cfr_capture_conf_arg *arg)
+{
+	struct ath12k_wmi_pdev *wmi = ar->wmi;
+	struct wmi_peer_cfr_capture_cmd_fixed_param *cmd;
+	struct sk_buff *skb;
+	int ret;
+
+	skb = ath12k_wmi_alloc_skb(wmi->wmi_ab, sizeof(*cmd));
+	if (!skb)
+		return -ENOMEM;
+
+	cmd = (struct wmi_peer_cfr_capture_cmd_fixed_param *)skb->data;
+	cmd->tlv_header = ath12k_wmi_tlv_cmd_hdr(WMI_TAG_PEER_CFR_CAPTURE_CMD,
+						 sizeof(*cmd));
+
+	cmd->request = cpu_to_le32(arg->request);
+	ether_addr_copy(cmd->mac_addr.addr, mac_addr);
+	cmd->vdev_id = cpu_to_le32(vdev_id);
+	cmd->periodicity = cpu_to_le32(arg->periodicity);
+	cmd->bandwidth = cpu_to_le32(arg->bw);
+	cmd->capture_method = cpu_to_le32(arg->method);
+
+	ret = ath12k_wmi_cmd_send(wmi, skb, WMI_PEER_CFR_CAPTURE_CMDID);
+
+	if (ret) {
+		ath12k_warn(ar->ab,
+			    "WMI vdev %d failed to send peer cfr capture cmd: %d\n",
+			    vdev_id, ret);
+		dev_kfree_skb(skb);
+	}
+
+	return ret;
+}
